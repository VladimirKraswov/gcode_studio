{
  "name": "@gcode-studio/cam",
  "version": "2.0.0",
  "description": "Independent TypeScript CAM kernel for 2D toolpath planning and G-code generation",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "check": "tsc --noEmit",
    "dev": "tsup src/index.ts --watch --dts",
    "example:profile": "tsx examples/profile.ts",
    "example:pocket": "tsx examples/pocket.ts"
  },
  "keywords": [
    "cam",
    "gcode",
    "cnc",
    "toolpath",
    "cad",
    "manufacturing"
  ],
  "author": "OpenAI",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.2.4",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
